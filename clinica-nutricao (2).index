<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Clínica de Nutrição · Anhanguera</title>
<link href="https://fonts.googleapis.com/css2?family=Inter+Tight:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Playfair+Display:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --cream: #FAF8F4;
    --sage: #8BAA8C;
    --sage-light: #C4D4C5;
    --sage-pale: #EEF3EE;
    --charcoal: #1E2420;
    --charcoal-soft: #2E3530;
    --warm-gray: #6B7068;
    --warm-gray-light: #9DA49A;
    --accent: #4A7C59;
    --accent-warm: #C8A97E;
    --accent-warm-light: #F0E4D0;
    --white: #FFFFFF;
    --border: rgba(30,36,32,0.08);
    --shadow: rgba(30,36,32,0.06);
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter Tight', sans-serif;
    background-color: var(--cream);
    color: var(--charcoal);
    overflow-x: hidden;
    line-height: 1.6;
  }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 20px 48px;
    display: flex; align-items: center; justify-content: space-between;
    background: rgba(250,248,244,0.88);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    transition: all 0.3s ease;
  }
  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-size: 17px;
    font-weight: 400;
    color: var(--charcoal);
    letter-spacing: 0.01em;
  }
  .nav-logo span { color: var(--accent); font-style: italic; }
  .nav-links { display: flex; gap: 36px; list-style: none; }
  .nav-links a {
    font-size: 13px;
    font-weight: 400;
    color: var(--warm-gray);
    text-decoration: none;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--charcoal); }
  .nav-cta {
    font-size: 13px;
    font-weight: 500;
    color: var(--white);
    background: var(--accent);
    padding: 10px 24px;
    border-radius: 100px;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: background 0.2s, transform 0.2s;
  }
  .nav-cta:hover { background: var(--charcoal); transform: translateY(-1px); }

  /* HERO */
  .hero {
    min-height: 100vh;
    padding: 140px 48px 80px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; top: 0; right: 0;
    width: 55%; height: 100%;
    background: linear-gradient(135deg, var(--sage-pale) 0%, #dde8dd 100%);
    z-index: 0;
    clip-path: polygon(12% 0, 100% 0, 100% 100%, 0% 100%);
  }
  .hero-content { position: relative; z-index: 1; }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 11px; font-weight: 500;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--accent);
    background: rgba(74,124,89,0.08);
    padding: 6px 16px; border-radius: 100px;
    margin-bottom: 32px;
    border: 1px solid rgba(74,124,89,0.15);
  }
  .hero-badge::before {
    content: ''; width: 6px; height: 6px; border-radius: 50%;
    background: var(--accent); display: block;
  }
  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(38px, 5vw, 62px);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--charcoal);
    margin-bottom: 24px;
  }
  .hero h1 em { font-style: italic; color: var(--accent); }
  .hero-sub {
    font-size: 17px; font-weight: 300;
    color: var(--warm-gray);
    line-height: 1.7;
    max-width: 480px;
    margin-bottom: 48px;
  }
  .hero-actions { display: flex; gap: 16px; flex-wrap: wrap; }
  .btn-primary {
    font-family: 'Inter Tight', sans-serif;
    font-size: 14px; font-weight: 500;
    color: var(--white);
    background: var(--accent);
    padding: 16px 36px; border-radius: 100px;
    text-decoration: none; border: none; cursor: pointer;
    letter-spacing: 0.02em;
    transition: all 0.25s ease;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .btn-primary:hover { background: var(--charcoal); transform: translateY(-2px); box-shadow: 0 12px 32px rgba(30,36,32,0.15); }
  .btn-secondary {
    font-family: 'Inter Tight', sans-serif;
    font-size: 14px; font-weight: 400;
    color: var(--charcoal);
    background: transparent;
    padding: 16px 28px; border-radius: 100px;
    text-decoration: none; border: 1.5px solid var(--border);
    cursor: pointer; letter-spacing: 0.02em;
    transition: all 0.25s ease;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .btn-secondary:hover { border-color: var(--charcoal); background: var(--white); }

  .hero-visual { position: relative; z-index: 1; }
  .hero-card {
    background: var(--white);
    border-radius: 20px;
    padding: 36px;
    box-shadow: 0 4px 40px var(--shadow), 0 1px 3px rgba(30,36,32,0.04);
  }
  .hero-card-label {
    font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em;
    color: var(--warm-gray-light); margin-bottom: 20px;
  }
  .price-row {
    display: flex; gap: 12px; margin-bottom: 24px;
  }
  .price-item {
    flex: 1; padding: 20px; border-radius: 14px;
    background: var(--sage-pale);
    text-align: center;
  }
  .price-item.accent-warm { background: var(--accent-warm-light); }
  .price-value {
    font-family: 'Playfair Display', serif;
    font-size: 28px; font-weight: 400;
    color: var(--charcoal);
    display: block;
  }
  .price-label { font-size: 12px; color: var(--warm-gray); margin-top: 4px; }
  .price-note {
    font-size: 12px; color: var(--warm-gray);
    background: var(--cream); padding: 12px 16px; border-radius: 10px;
    line-height: 1.5; margin-bottom: 20px;
  }
  .price-note strong { color: var(--charcoal); font-weight: 500; }
  .hero-stats {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px;
    background: var(--border); border-radius: 12px; overflow: hidden;
  }
  .stat {
    background: var(--white); padding: 16px 12px; text-align: center;
  }
  .stat-num {
    font-family: 'Playfair Display', serif;
    font-size: 22px; color: var(--accent);
  }
  .stat-text { font-size: 11px; color: var(--warm-gray); margin-top: 2px; }

  /* SECTION BASE */
  section { padding: 100px 48px; }
  .section-tag {
    font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.14em;
    color: var(--warm-gray-light); margin-bottom: 16px; display: block;
  }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 400; line-height: 1.15;
    letter-spacing: -0.015em;
    color: var(--charcoal); margin-bottom: 16px;
  }
  .section-title em { font-style: italic; color: var(--accent); }
  .section-sub {
    font-size: 16px; font-weight: 300; color: var(--warm-gray);
    line-height: 1.7; max-width: 540px;
  }
  .section-header { margin-bottom: 60px; }

  /* HOW IT WORKS */
  .how { background: var(--white); }
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--border);
    border-radius: 20px;
    overflow: hidden;
  }
  .step {
    background: var(--white);
    padding: 36px 32px;
    position: relative;
    transition: background 0.2s;
  }
  .step:hover { background: var(--sage-pale); }
  .step-num {
    font-family: 'Playfair Display', serif;
    font-size: 48px; font-weight: 400;
    color: var(--sage-light);
    line-height: 1; margin-bottom: 20px;
    display: block;
  }
  .step-title {
    font-size: 16px; font-weight: 500;
    color: var(--charcoal); margin-bottom: 10px;
  }
  .step-text { font-size: 14px; font-weight: 300; color: var(--warm-gray); line-height: 1.65; }
  .step-tag {
    display: inline-block; margin-top: 16px;
    font-size: 11px; font-weight: 500;
    color: var(--accent); background: rgba(74,124,89,0.08);
    padding: 4px 12px; border-radius: 100px;
  }

  /* TEAM */
  .team { background: var(--cream); }
  .team-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; max-width: 800px;
  }
  .team-card {
    background: var(--white);
    border-radius: 20px; padding: 36px;
    border: 1px solid var(--border);
    transition: transform 0.25s, box-shadow 0.25s;
  }
  .team-card:hover { transform: translateY(-4px); box-shadow: 0 16px 40px var(--shadow); }
  .team-role {
    font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em;
    color: var(--accent); margin-bottom: 12px;
  }
  .team-name {
    font-family: 'Playfair Display', serif;
    font-size: 22px; font-weight: 400; color: var(--charcoal); margin-bottom: 8px;
  }
  .team-bio { font-size: 13.5px; font-weight: 300; color: var(--warm-gray); line-height: 1.65; }
  .team-crn {
    margin-top: 20px; padding-top: 20px;
    border-top: 1px solid var(--border);
    font-size: 12px; color: var(--warm-gray-light);
    letter-spacing: 0.02em;
  }
  .team-coords {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; max-width: 800px; margin-top: 24px;
  }
  .team-coord-card {
    background: var(--sage-pale);
    border-radius: 16px; padding: 28px;
  }
  .team-coord-role { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--sage); margin-bottom: 8px; }
  .team-coord-name { font-size: 17px; font-weight: 500; color: var(--charcoal); }
  .team-coord-detail { font-size: 13px; font-weight: 300; color: var(--warm-gray); margin-top: 4px; }

  /* VIDEOS */
  .videos { background: var(--charcoal); }
  .videos .section-title { color: var(--white); }
  .videos .section-sub { color: rgba(255,255,255,0.5); }
  .videos .section-tag { color: var(--sage); }
  .video-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px;
  }
  .video-card {
    border-radius: 16px; overflow: hidden;
    position: relative; cursor: pointer;
    transition: transform 0.25s, box-shadow 0.25s;
    text-decoration: none; display: block;
  }
  .video-card:hover { transform: scale(1.02); box-shadow: 0 24px 60px rgba(0,0,0,0.35); }
  .video-thumb {
    width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block;
    filter: brightness(0.7);
    transition: filter 0.25s;
  }
  .video-card:hover .video-thumb { filter: brightness(0.55); }
  .video-play {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 52px; height: 52px;
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(8px);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    border: 1.5px solid rgba(255,255,255,0.3);
    transition: background 0.2s, transform 0.2s;
  }
  .video-card:hover .video-play { background: rgba(255,255,255,0.25); transform: translate(-50%, -50%) scale(1.1); }
  .video-info {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 28px 24px 20px;
    background: linear-gradient(transparent, rgba(20,28,22,0.9));
  }
  .video-tag { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--sage-light); margin-bottom: 6px; }
  .video-title { font-size: 15px; font-weight: 500; color: var(--white); line-height: 1.3; }
  .video-desc { font-size: 12px; font-weight: 300; color: rgba(255,255,255,0.6); margin-top: 4px; }

  /* LOCATION */
  .location { background: var(--white); }
  .location-inner {
    display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center;
  }
  .location-details { }
  .location-name {
    font-family: 'Playfair Display', serif;
    font-size: 26px; font-weight: 400; color: var(--charcoal); margin-bottom: 12px;
  }
  .location-address { font-size: 15px; font-weight: 300; color: var(--warm-gray); line-height: 1.7; margin-bottom: 32px; }
  .location-map-wrap {
    border-radius: 20px; overflow: hidden;
    box-shadow: 0 8px 40px var(--shadow);
    border: 1px solid var(--border);
    aspect-ratio: 4/3;
  }
  .location-map-wrap iframe { width: 100%; height: 100%; border: none; display: block; }
  .location-info-cards { display: flex; flex-direction: column; gap: 12px; }
  .loc-card {
    display: flex; align-items: flex-start; gap: 16px;
    padding: 16px 20px; border-radius: 14px;
    background: var(--cream); border: 1px solid var(--border);
  }
  .loc-icon {
    width: 36px; height: 36px; border-radius: 10px;
    background: var(--sage-pale); display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; font-size: 16px;
  }
  .loc-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--warm-gray-light); margin-bottom: 4px; }
  .loc-value { font-size: 14px; font-weight: 400; color: var(--charcoal); }
  .loc-sub { font-size: 12px; color: var(--warm-gray); }

  /* BOOKING */
  .booking { background: var(--sage-pale); }
  .booking-inner {
    display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start;
  }
  .booking-info { padding-top: 8px; }
  .booking-points { list-style: none; margin-top: 36px; display: flex; flex-direction: column; gap: 16px; }
  .booking-point {
    display: flex; align-items: flex-start; gap: 14px;
  }
  .booking-point-dot {
    width: 24px; height: 24px; border-radius: 50%;
    background: var(--accent); color: var(--white);
    font-size: 11px; font-weight: 600;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; margin-top: 1px;
  }
  .booking-point-text { font-size: 14px; font-weight: 300; color: var(--warm-gray); line-height: 1.6; }
  .booking-point-text strong { font-weight: 500; color: var(--charcoal); }

  /* FORM */
  .booking-form {
    background: var(--white);
    border-radius: 24px; padding: 44px;
    box-shadow: 0 4px 40px var(--shadow);
  }
  .form-title {
    font-family: 'Playfair Display', serif;
    font-size: 22px; font-weight: 400; color: var(--charcoal);
    margin-bottom: 8px;
  }
  .form-subtitle { font-size: 13px; color: var(--warm-gray); margin-bottom: 32px; }
  .form-group { margin-bottom: 20px; }
  .form-label {
    display: block; font-size: 11px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--warm-gray); margin-bottom: 8px;
  }
  .form-control {
    width: 100%; padding: 14px 18px;
    font-family: 'Inter Tight', sans-serif;
    font-size: 14px; font-weight: 300;
    color: var(--charcoal);
    background: var(--cream); border: 1.5px solid var(--border);
    border-radius: 12px; outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    appearance: none;
  }
  .form-control:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(74,124,89,0.1);
  }
  .form-control::placeholder { color: var(--warm-gray-light); }
  select.form-control { cursor: pointer; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .form-submit {
    width: 100%; padding: 16px;
    font-family: 'Inter Tight', sans-serif;
    font-size: 14px; font-weight: 500;
    color: var(--white); background: var(--accent);
    border: none; border-radius: 12px; cursor: pointer;
    letter-spacing: 0.02em; margin-top: 8px;
    transition: all 0.25s ease;
  }
  .form-submit:hover { background: var(--charcoal); transform: translateY(-1px); box-shadow: 0 8px 24px rgba(30,36,32,0.15); }
  .form-note { font-size: 11px; color: var(--warm-gray-light); text-align: center; margin-top: 16px; line-height: 1.5; }

  /* SUCCESS */
  .success-msg {
    display: none; text-align: center; padding: 48px 24px;
  }
  .success-icon {
    width: 64px; height: 64px; border-radius: 50%;
    background: var(--sage-pale); display: flex; align-items: center; justify-content: center;
    margin: 0 auto 20px; font-size: 28px;
  }
  .success-title {
    font-family: 'Playfair Display', serif;
    font-size: 22px; color: var(--charcoal); margin-bottom: 10px;
  }
  .success-text { font-size: 14px; color: var(--warm-gray); line-height: 1.65; }

  /* FOOTER */
  footer {
    background: var(--charcoal-soft);
    padding: 60px 48px 40px;
  }
  .footer-inner {
    display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 48px;
    padding-bottom: 48px; border-bottom: 1px solid rgba(255,255,255,0.06);
    margin-bottom: 32px;
  }
  .footer-brand {
    font-family: 'Playfair Display', serif;
    font-size: 18px; color: var(--white); font-weight: 400; margin-bottom: 12px;
  }
  .footer-brand span { color: var(--sage-light); font-style: italic; }
  .footer-desc { font-size: 13px; font-weight: 300; color: rgba(255,255,255,0.4); line-height: 1.7; max-width: 280px; }
  .footer-heading { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--sage); margin-bottom: 16px; }
  .footer-list { list-style: none; display: flex; flex-direction: column; gap: 8px; }
  .footer-list li { font-size: 13px; font-weight: 300; color: rgba(255,255,255,0.45); line-height: 1.5; }
  .footer-list li strong { color: rgba(255,255,255,0.7); font-weight: 400; }
  .footer-bottom {
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 12px;
  }
  .footer-copy { font-size: 12px; color: rgba(255,255,255,0.25); }
  .footer-crns { display: flex; gap: 24px; flex-wrap: wrap; }
  .footer-crn { font-size: 11px; color: rgba(255,255,255,0.25); letter-spacing: 0.02em; }

  /* ANIMATIONS */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .fade-up { animation: fadeUp 0.7s ease forwards; }
  .fade-up-1 { animation-delay: 0.1s; opacity: 0; }
  .fade-up-2 { animation-delay: 0.2s; opacity: 0; }
  .fade-up-3 { animation-delay: 0.35s; opacity: 0; }
  .fade-up-4 { animation-delay: 0.5s; opacity: 0; }

  /* MOBILE */
  @media (max-width: 900px) {
    nav { padding: 16px 24px; }
    .nav-links { display: none; }
    section { padding: 72px 24px; }
    .hero { padding: 100px 24px 60px; grid-template-columns: 1fr; gap: 40px; }
    .hero::before { display: none; }
    .steps-grid { grid-template-columns: 1fr; }
    .team-grid { grid-template-columns: 1fr; }
    .team-coords { grid-template-columns: 1fr; }
    .video-grid { grid-template-columns: 1fr; }
    .location-inner { grid-template-columns: 1fr; gap: 36px; }
    .booking-inner { grid-template-columns: 1fr; gap: 40px; }
    .form-row { grid-template-columns: 1fr; }
    .footer-inner { grid-template-columns: 1fr; gap: 32px; }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-logo">Clínica de <span>Nutrição</span></div>
  <ul class="nav-links">
    <li><a href="#como-funciona">Como funciona</a></li>
    <li><a href="#equipe">Equipe</a></li>
    <li><a href="#aprender">Aprender</a></li>
    <li><a href="#onde">Onde</a></li>
  </ul>
  <a href="#agendar" class="nav-cta">Agendar consulta</a>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-content">
    <div class="hero-badge fade-up fade-up-1">Universidade Anhanguera · Centro Clínico</div>
    <h1 class="fade-up fade-up-2">
      Nutrição clínica com <em>cuidado real</em> e base científica.
    </h1>
    <p class="hero-sub fade-up fade-up-3">
      Atendimento supervisionado por nutricionistas formadas, orientado pelo Guia Alimentar para a População Brasileira. Do seu histórico alimentar ao seu plano personalizado.
    </p>
    <div class="hero-actions fade-up fade-up-4">
      <a href="#agendar" class="btn-primary">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
        Agendar minha consulta
      </a>
      <a href="#como-funciona" class="btn-secondary">
        Como funciona
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
  <div class="hero-visual fade-up fade-up-3">
    <div class="hero-card">
      <div class="hero-card-label">Investimento por consulta</div>
      <div class="price-row">
        <div class="price-item">
          <span class="price-value">R$ 25</span>
          <div class="price-label">1ª consulta</div>
        </div>
