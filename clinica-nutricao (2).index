<!-- BOOKING -->
<section class="booking" id="agendar">
  <div class="booking-inner">
    <div class="booking-info">
      <span class="section-tag">Agendamento</span>
      <h2 class="section-title">Pronto para <em>começar?</em></h2>
      <ul class="booking-points">
        <li class="booking-point">
          <div class="booking-point-dot">1</div>
          <div class="booking-point-text"><strong>Preencha o formulário</strong> ao lado com seus dados e preferências de horário.</div>
        </li>
        <li class="booking-point">
          <div class="booking-point-dot">2</div>
          <div class="booking-point-text"><strong>Confirmaremos o agendamento</strong> por WhatsApp em até 24h.</div>
        </li>
        <li class="booking-point">
          <div class="booking-point-dot">3</div>
          <div class="booking-point-text"><strong>Chegue 10 minutos antes.</strong> A sala estará preparada com tudo que você precisa.</div>
        </li>
        <li class="booking-point">
          <div class="booking-point-dot">4</div>
          <div class="booking-point-text"><strong>Leve exames de sangue</strong> recentes se tiver. Facilitam a anamnese, mas não são obrigatórios.</div>
        </li>
      </ul>
    </div>

    <div class="booking-form" id="form-container">
      <div class="form-title">Solicitar agendamento</div>
      <p class="form-subtitle">Preencha abaixo — responderemos em até um dia útil.</p>

      <form id="booking-form" onsubmit="handleSubmit(event)">
        <div class="form-group">
          <label class="form-label" for="nome">Nome completo</label>
          <input type="text" id="nome" class="form-control" placeholder="Como você se chama?" required>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="idade">Idade</label>
            <input type="number" id="idade" class="form-control" placeholder="Ex: 28" min="1" max="120">
          </div>
          <div class="form-group">
            <label class="form-label" for="whatsapp">WhatsApp</label>
            <input type="tel" id="whatsapp" class="form-control" placeholder="(11) 99999-9999" required>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label" for="objetivo">Principal objetivo</label>
          <select id="objetivo" class="form-control">
            <option value="" disabled selected>Selecione uma opção</option>
            <option>Reeducação alimentar</option>
            <option>Perda de peso com saúde</option>
            <option>Ganho de massa muscular</option>
            <option>Controle de exames / condição clínica</option>
            <option>Melhora na energia e disposição</option>
            <option>Nutrição comportamental</option>
            <option>Outro</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label" for="turno">Turno de preferência</label>
          <select id="turno" class="form-control">
            <option value="" disabled selected>Qual período funciona melhor?</option>
            <option>Manhã</option>
            <option>Tarde</option>
            <option>Qualquer horário</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label" for="obs">Algo que devemos saber? (opcional)</label>
          <textarea id="obs" class="form-control" rows="3" placeholder="Alergias, condições de saúde, dúvidas..." style="resize:vertical; min-height:80px;"></textarea>
        </div>
        <button type="submit" class="form-submit">Enviar solicitação de agendamento</button>
        <p class="form-note">Seus dados são tratados com sigilo e usados apenas para o agendamento. Nenhuma informação é compartilhada.</p>
      </form>

      <div class="success-msg" id="success-msg">
        <div class="success-icon">✓</div>
        <div class="success-title">Solicitação recebida!</div>
        <p class="success-text">Entraremos em contato pelo WhatsApp informado em até um dia útil para confirmar seu agendamento. Fique de olho!</p>
      </div>
    </div>
  </div>
</section>

